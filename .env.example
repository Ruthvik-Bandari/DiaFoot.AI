# ============================================================================
# DiaFoot.AI v2 — Environment Variables Template
# Copy to .env and fill in values: cp .env.example .env
# ============================================================================

# Weights & Biases
WANDB_API_KEY=
WANDB_PROJECT=DiaFootAI-v2
WANDB_ENTITY=

# DVC Remote Storage (S3/GCS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# MLflow (optional)
MLFLOW_TRACKING_URI=

# H100 Optimizations (set in SLURM scripts)
TORCH_BACKENDS_CUDA_MATMUL_ALLOW_TF32=1
TORCH_BACKENDS_CUDNN_ALLOW_TF32=1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
